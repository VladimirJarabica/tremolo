generator kysely {
  provider     = "prisma-kysely"
  // Optionally provide a destination directory for the generated file
  // and a filename of your choice
  output       = "."
  fileName     = "types.ts"
  // Optionally generate runtime enums to a separate file
  enumFileName = "enums.ts"
}

datasource db {
  provider = "postgresql"
}

enum Meter {
  m_4_4
  m_3_4
  m_2_4
  m_6_8
  m_3_8
  m_2_2
}

enum Scale {
  // Major - sharps
  C
  G
  D
  A
  E
  B
  Fs
  Cs
  // Major - flats
  F
  Bb
  Eb
  Ab
  Db
  Gb
  Cb
  // Minor - sharps
  Am
  Em
  Bm
  Fsm
  Csm
  Gsm
  Dsm
  Asm
  // Minor - flats
  Dm
  Gm
  Cm
  Fm
  Bbm
  Ebm
  Abm
}

model Tag {
  id   String @id @default(dbgenerated("gen_random_uuid()"))
  name String @unique

  sheets Sheet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Sheet {
  id      String @id @default(dbgenerated("gen_random_uuid()"))
  slug    String @unique
  tags    Tag[]
  title   String @default("Untitled")
  content String
  meter   Meter
  tempo   Int
  scale   Scale

  userId String
  user   User   @relation(fields: [userId], references: [id])

  listItems ListItem[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model List {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  name           String
  sheetIdsOrder  String[] @default([])

  items ListItem[]

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ListItem {
  transpose Int @default(0)

  list   List   @relation(fields: [listId], references: [id])
  listId String

  sheet   Sheet  @relation(fields: [sheetId], references: [id])
  sheetId String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@id([listId, sheetId])
}

model User {
  id    String @id @default(dbgenerated("gen_random_uuid()"))
  email String @unique

  authId String? @unique

  sheets Sheet[]
  lists  List[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}
